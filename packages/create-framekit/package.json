{
  "name": "@mauriciodmo/create-framekit",
  "version": "0.1.0-alpha.1",
  "type": "module",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=11.14.0"
  },
  "license": "Apache-2.0",
