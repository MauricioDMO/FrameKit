{
  "name": "@mauriciodmo/create-framekit",
  "version": "0.1.0-alpha.1",
  "type": "module",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=11.14.0"
  },
  "license": "Apache-2.0",
  "bugs": "https://github.com/MauricioDMO/FrameKit/issues",
  "files": [
    "dist",
    "template",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "create-framekit": "./dist/cli.js"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "description": "Scaffold a new FrameKit project with one command",
  "keywords": [
    "framekit",
    "scaffold",
    "template",
    "nextjs",
    "react"
  ],
  "homepage": "https://github.com/MauricioDMO/FrameKit#readme",
  "author": "MauricioDMO <mauriciodmo@proton.me>",
  "repository": {
    "type": "git",
    "url": "https://github.com/MauricioDMO/FrameKit.git",
    "directory": "packages/create-framekit"
  },
  "scripts": {
    "build": "tsdown && pnpm check:dist",
    "check:dist": "tsx ../framekit/scripts/check-dist.ts .",
    "lint": "eslint src tsdown.config.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm typecheck"
  },
  "devDependencies": {
    "@types/node": "^20",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tsdown": "^0.20",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
