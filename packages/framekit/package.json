{
  "name": "@mauriciodmo/framekit",
  "version": "0.5.0",
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "license": "Apache-2.0",
  "bugs": "https://github.com/MauricioDMO/FrameKit/issues",
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "framekit": "./bin/framekit.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./editor": {
      "types": "./dist/editor.d.ts",
      "import": "./dist/editor.js",
      "default": "./dist/editor.js"
    },
    "./studio": {
      "types": "./dist/studio.d.ts",
      "import": "./dist/studio.js",
      "default": "./dist/studio.js"
    },
    "./studio/root": {
      "types": "./dist/studio-root.d.ts",
      "import": "./dist/studio-root.js",
      "default": "./dist/studio-root.js"
    },
    "./dev": {
      "types": "./dist/dev.d.ts",
      "import": "./dist/dev.js",
      "default": "./dist/dev.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "Template-based image editor with visual Studio, CLI, and code generation for React and Next.js",
  "keywords": [
    "image-editor",
    "template",
    "react",
    "nextjs",
    "framekit",
    "visual-editor"
  ],
  "homepage": "https://github.com/MauricioDMO/FrameKit#readme",
  "author": "MauricioDMO <mauriciodmo@proton.me>",
  "repository": {
    "type": "git",
    "url": "https://github.com/MauricioDMO/FrameKit.git",
    "directory": "packages/framekit"
  },
  "scripts": {
    "lint": "eslint src scripts tsdown.config.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/types/tsconfig.json",
    "build:js": "tsdown",
    "build:css": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify",
    "check:dist": "tsx scripts/check-dist.ts",
    "build": "pnpm build:js && pnpm build:css && pnpm check:dist",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm typecheck"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "lucide-react": "^1.24.0",
    "modern-screenshot": "^4.7.0",
    "tsx": "^4"
  },
  "peerDependencies": {
    "next": ">=16 <17",
    "react": ">=19 <20",
    "react-dom": ">=19 <20"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsdown": "^0.20",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
