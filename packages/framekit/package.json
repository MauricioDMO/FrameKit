{
  "name": "@mauriciodmo/framekit",
  "version": "0.1.0-alpha.1",
  "type": "module",
  "license": "Apache-2.0",
  "files": ["dist", "README.md", "LICENSE"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./editor": {
      "types": "./dist/editor.d.ts",
      "import": "./dist/editor.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint src scripts tsdown.config.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/types/tsconfig.json",
    "codegen": "node src/codegen/generate-template-registry.mjs",
    "build:js": "tsdown",
    "build:css": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify",
    "check:dist": "node scripts/check-dist.mjs",
    "build": "pnpm build:js && pnpm build:css && pnpm check:dist"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "modern-screenshot": "^4.7.0"
  },
  "peerDependencies": {
    "next": ">=16 <17",
    "react": ">=19 <20",
    "react-dom": ">=19 <20"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsdown": "^0.20",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
